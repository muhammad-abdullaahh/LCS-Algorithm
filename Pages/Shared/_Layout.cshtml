<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LCS Plagiarism Checker</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-brand">
                <a asp-area="" asp-page="/Index">LCS CHECKER</a>
            </div>
            <div class="nav-links">
                <a asp-area="" asp-page="/Index">Home</a>
                <a asp-area="" asp-page="/About">About</a>
            </div>
        </nav>
    </header>

    <main role="main" class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            &copy; @DateTime.Now.Year - LCS Plagiarism Checker
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
